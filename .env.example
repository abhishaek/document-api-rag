# Copy this file to .env and fill in real values.
# .env is git-ignored so secrets never get committed.

# --- App ---
APP_NAME=document-api-rag
ENVIRONMENT=development
DEBUG=true

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- MongoDB ---
# Atlas Local (Docker): use directConnection. Running the API on your host
# against the Dockerized Mongo, use localhost:
MONGODB_URI=mongodb://localhost:27018/?directConnection=true
# Atlas Cloud instead: MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/...
MONGODB_DB_NAME=document_rag

# --- Auth / JWT ---
# SECRET_KEY is required and has no default, so a real secret is never committed.
# Generate one and append it to your .env:
#     echo "SECRET_KEY=$(openssl rand -hex 32)" >> .env
# Keep the line below commented until you have a real value. An empty
# `SECRET_KEY=` passes validation and lets the app boot, then fails at login with
# a 500 (pyjwt rejects an empty HMAC key) — a missing key fails at startup instead.
# SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Document storage ---
# Uploaded files are stored on disk, not in MongoDB — the DB keeps only a
# reference. STORAGE_DIR is the root of the filesystem backend (git-ignored).
STORAGE_DIR=./var/storage
# Uploads larger than this are rejected before any bytes are written (25 MiB).
MAX_UPLOAD_SIZE_BYTES=26214400

# --- Embedding (Voyage) ---
# Required to actually embed chunks. Without it the app still runs, but ingestion
# reaches `failed` at the embedding step. Get a key at dashboard.voyageai.com.
# VOYAGE_API_KEY=
# voyage-4-large @ 1024 dims is the default; changing either means rebuilding the
# chunks vector index.
EMBEDDING_MODEL=voyage-4-large
EMBEDDING_DIMENSIONS=1024
# Auto-retry transient Voyage failures (rate limits, network, 5xx) with backoff,
# so a momentary blip doesn't fail an ingest. Permanent errors (bad key) aren't
# retried. Timeout caps a single request.
EMBEDDING_MAX_RETRIES=3
EMBEDDING_TIMEOUT_SECONDS=30

# --- Chunking ---
# Characters per chunk and overlap between consecutive chunks. A primary lever on
# retrieval quality — tune per corpus. CHUNK_OVERLAP must be < CHUNK_SIZE.
CHUNK_SIZE=2000
CHUNK_OVERLAP=200

# --- Logging ---
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_JSON: true in production for structured logs; false for readable dev logs.
LOG_LEVEL=INFO
LOG_JSON=false

# --- CORS ---
# Comma-separated list of browser origins allowed to call the API.
# Leave as-is for local frontend dev; add real domains in production.
CORS_ORIGINS=http://localhost:3000

# --- Added in later phases ---
# ANTHROPIC_API_KEY=
# DATABASE_URL=postgresql+psycopg://rag:rag@localhost:5432/rag
